# CPI Backend — Puertos de microservicios
# Copia este archivo a .env y ajusta según tu entorno.
# ─────────────────────────────────────────────────────────────────────────────

# Microservicios (.NET 9 / ASP.NET Core)
AUTH_SERVICE_PORT=5258
CATALOG_SERVICE_PORT=5131
INVENTORY_SERVICE_PORT=5035
SALES_SERVICE_PORT=5215

# Swagger UI de cada servicio
# AUTH_SWAGGER=http://localhost:5258/swagger
# CATALOG_SWAGGER=http://localhost:5131/swagger
# INVENTORY_SWAGGER=http://localhost:5035/swagger
# SALES_SWAGGER=http://localhost:5215/swagger

# Base de datos PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=CPI
DB_USER=postgres
DB_PASSWORD=Freedom0925,

# JWT (mismo secret que en appsettings.Development.json)
JWT_SECRET=
JWT_ISSUER=CPI
JWT_AUDIENCE=CPI
JWT_EXPIRY_HOURS=8
